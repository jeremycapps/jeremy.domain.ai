{
  "name": "jeremy-domain-resume-router",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "npm run build && node --test dist/test/*.test.js",
    "live:prophet": "tsx scripts/runLiveProphetEvaluation.ts",
    "live:resume-failure-rerouting": "tsx scripts/resumeFailureRerouting.ts",
    "live:prophet:attempt2": "tsx scripts/runLiveProphetAttempt2.ts",
    "checkpoint:attempt2:validation": "tsx scripts/reprocessAttempt2Validation.ts",
    "checkpoint:attempt2:architect": "tsx scripts/resolveAttempt2ArchitectCheckpoint.ts"
  },
  "dependencies": {
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
